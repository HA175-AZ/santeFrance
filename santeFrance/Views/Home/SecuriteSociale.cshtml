@{
    ViewData["Title"] = "Sécurité sociale";
}

<section class="page-header">
    <div class="container">
        <h1>S'inscrire à la Sécurité Sociale</h1>
        <p class="lead">C'est une étape gratuite et obligatoire pour être remboursé de vos frais médicaux en France.</p>
    </div>
</section>

<section class="steps-section">
    <div class="container">
        <!-- Étape 1 -->
        <div class="step-card step-right">
            <div class="step-content">
                <span class="step-label">ÉTAPE 1</span>
                <h3>Inscription Administrative</h3>
                <p>Inscrivez-vous d'abord dans votre établissement d'enseignement supérieur.</p>
            </div>
            <div class="step-icon-wrapper">
                <div class="step-icon blue">
                    <span>📝</span>
                </div>
            </div>
        </div>

        <!-- Étape 2 -->
        <div class="step-card step-left">
            <div class="step-icon-wrapper">
                <div class="step-icon blue">
                    <span>🌐</span>
                </div>
            </div>
            <div class="step-content">
                <span class="step-label">ÉTAPE 2</span>
                <h3>Plateforme etudiant-etranger.ameli.fr</h3>
                <p>Créez votre compte sur le site officiel des soins arrêtés en France.</p>
            </div>
        </div>

        <!-- Étape 3 -->
        <div class="step-card step-right">
            <div class="step-content">
                <span class="step-label">ÉTAPE 3</span>
                <h3>Dépôt des documents</h3>
                <p>Téléchargez votre passeport, titre de séjour, certificat de scolarité et RIB.</p>
            </div>
            <div class="step-icon-wrapper">
                <div class="step-icon blue">
                    <span>📄</span>
                </div>
            </div>
        </div>

        <!-- Étape 4 -->
        <div class="step-card step-left">
            <div class="step-icon-wrapper">
                <div class="step-icon blue">
                    <span>⏳</span>
                </div>
            </div>
            <div class="step-content">
                <span class="step-label">ÉTAPE 4</span>
                <h3>Attestation de droits</h3>
                <p>Recevez votre attestation provisoire pour être remboursé immédiatement.</p>
            </div>
        </div>

        <!-- Étape 5 -->
        <div class="step-card step-right">
            <div class="step-content">
                <span class="step-label">ÉTAPE 5</span>
                <h3>Carte Vitale</h3>
                <p>Dans les mois suivants, vous pourrez commander votre carte Vitale.</p>
            </div>
            <div class="step-icon-wrapper">
                <div class="step-icon blue">
                    <span>💳</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Prêt à commencer -->
<section class="ready-section">
    <div class="container">
        <div class="ready-box">
            <h2>Prêt à commencer ?</h2>
            <p>Suivez ces étapes sur la plateforme officielle pour les étudiants internationaux.</p>
            <a href="https://etudiant-etranger.ameli.fr" target="_blank" class="btn-ameli">
                Aller sur Ameli.fr
                <span class="external-icon">↗</span>
            </a>
        </div>
    </div>
</section>

<!-- Que faire en attendant -->
<section class="waiting-section">
    <div class="container">
        <div class="warning-box">
            <div class="warning-icon">⚠️</div>
            <div class="warning-content">
                <h3>Que faire en attendant ?</h3>
                <p>
                    Le traitement peut prendre plusieurs semaines, surtout pendant les "rentrées de santé" (décembre-janvier).
                    Gardez précieusement toutes les factures de santé pour vous les faire rembourser rétroactivement.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Documents nécessaires -->
<section class="documents-section">
    <div class="container">
        <h2 class="section-title">Documents nécessaires</h2>
        <div class="documents-grid">
            <div class="document-card">
                <div class="document-icon">🛂</div>
                <h3>Passeport ou Carte d'identité</h3>
                <p>Document d'identité en cours de validité</p>
            </div>

            <div class="document-card">
                <div class="document-icon">📜</div>
                <h3>Titre de séjour</h3>
                <p>Pour les étudiants hors UE</p>
            </div>

            <div class="document-card">
                <div class="document-icon">🎓</div>
                <h3>Certificat de scolarité</h3>
                <p>Délivré par votre établissement</p>
            </div>

            <div class="document-card">
                <div class="document-icon">🏦</div>
                <h3>RIB (Relevé d'Identité Bancaire)</h3>
                <p>Pour recevoir les remboursements</p>
            </div>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="faq-section">
    <div class="container">
        <h2 class="section-title">Questions fréquentes</h2>

        <div class="faq-list">
            <div class="faq-item">
                <h3>💰 C'est gratuit ?</h3>
                <p>Oui, l'inscription à la Sécurité sociale est totalement gratuite pour les étudiants.</p>
            </div>

            <div class="faq-item">
                <h3>⏱️ Combien de temps ça prend ?</h3>
                <p>Comptez entre 2 à 6 semaines pour recevoir votre attestation de droits.</p>
            </div>

            <div class="faq-item">
                <h3>🏥 Je peux consulter un médecin en attendant ?</h3>
                <p>Oui ! Gardez vos factures, vous serez remboursé rétroactivement une fois inscrit.</p>
            </div>

            <div class="faq-item">
                <h3>📱 J'ai besoin d'aide pour m'inscrire ?</h3>
                <p>Contactez le service d'accueil de votre université ou appelez le 36 46 (Ameli).</p>
            </div>
        </div>
    </div>
</section>