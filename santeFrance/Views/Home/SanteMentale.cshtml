@{
    ViewData["Title"] = "Santé mentale";
}

<!-- Hero Section - Santé Mentale -->
<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1>
                    Prendre soin de son<br />
                    <span class="text-gradient">équilibre mental.</span>
                </h1>
                <p class="hero-description">
                    S'installer dans un nouveau pays est un défi. Il est normal de se sentir seul, stressé ou fatigué.
                    Nous sommes là pour vous orienter vers des solutions bienveillantes et gratuites.
                </p>
                <a href="#" class="btn-primary">Parler à quelqu'un maintenant</a>
            </div>
            <div class="hero-image">
                <div class="image-container">
                    <img src="~/images/international.jpg" alt="Étudiants pratiquant la méditation en plein air" />
                    <div class="floating-icon">
                        <svg width="48" height="48" fill="#7C3AED" viewBox="0 0 24 24">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z" />
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quand demander de l'aide -->
<section class="help-section">
    <div class="container">
        <h2 class="section-title">Quand demander de l'aide ?</h2>
        <div class="help-cards">
            <div class="help-card">
                <div class="help-icon">
                    <svg width="48" height="48" fill="#7C3AED" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
                        <circle cx="12" cy="8" r="1.5" fill="currentColor" />
                        <path d="M12 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <h3>Isolement</h3>
                <p>Vous n'avez plus envie de sortir ou de voir du monde.</p>
            </div>

            <div class="help-card">
                <div class="help-icon">
                    <svg width="48" height="48" fill="#7C3AED" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
                        <circle cx="12" cy="8" r="1.5" fill="currentColor" />
                        <path d="M12 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <h3>Troubles du sommeil</h3>
                <p>Difficultés à s'endormir ou réveils fréquents.</p>
            </div>

            <div class="help-card">
                <div class="help-icon">
                    <svg width="48" height="48" fill="#7C3AED" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
                        <circle cx="12" cy="8" r="1.5" fill="currentColor" />
                        <path d="M12 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <h3>Anxiété persistante</h3>
                <p>Inquiétude constante face aux études ou à l'avenir.</p>
            </div>
        </div>
    </div>
</section>

<!-- Ressources gratuites -->
<section class="resources-section">
    <div class="container">
        <h2 class="section-title">Ressources gratuites disponibles</h2>
        <div class="resources-grid">
            <!-- BAPU -->
            <div class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon">
                        <svg width="32" height="32" fill="#7C3AED" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </svg>
                    </div>
                    <span class="badge badge-gratuit">GRATUIT</span>
                </div>
                <h3>BAPU</h3>
                <p>Bureaux d'Aide Psychologique Universitaire. Consultations 100% gratuites et confidentielles.</p>
                <a href="https://annuaire.action-sociale.org/etablissements/jeunes-handicapes/bureau-d-aide-psychologique-universitaire--b-a-p-u---221.html#google_vignette" class="link-arrow">En savoir plus →</a>
            </div>

            <!-- Service de santé étudiante -->
            <div class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon">
                        <svg width="32" height="32" fill="#EF4444" viewBox="0 0 24 24">
                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
                        </svg>
                    </div>
                    <span class="badge badge-campus">SUR CAMPUS</span>
                </div>
                <h3>Service de santé étudiante</h3>
                <p>Chaque université dispose d'une équipe de psychologues dédiée aux étudiants.</p>
                <a href="https://santetudiant.com/" class="link-arrow">En savoir plus →</a>
            </div>

            <!-- Nightline France -->
            <div class="resource-card">
                <div class="resource-header">
                    <div class="resource-icon">
                        <svg width="32" height="32" fill="#3B82F6" viewBox="0 0 24 24">
                            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z" />
                        </svg>
                    </div>
                    <span class="badge badge-ecoute">ÉCOUTE</span>
                </div>
                <h3>Nightline France</h3>
                <p>Service d'écoute par et pour les étudiants, ouvert le soir.</p>
                <a href="https://www.nightline.fr/" class="link-arrow">En savoir plus →</a>
            </div>
        </div>
    </div>
</section>

<!-- Plus d'informations -->
<section class="mental-health-info">
    <div class="container">
        <div class="info-grid-mental">
            <div class="mental-info-card">
                <h3>🧠 C'est normal de ne pas aller bien</h3>
                <p>
                    La santé mentale est aussi importante que la santé physique. Demander de l'aide n'est pas un signe
                    de faiblesse, c'est une preuve de courage.
                </p>
            </div>

            <div class="mental-info-card">
                <h3>🤝 Vous n'êtes pas seul(e)</h3>
                <p>
                    De nombreux étudiants vivent des moments difficiles. Il existe des professionnels formés pour vous écouter
                    et vous accompagner, sans jugement.
                </p>
            </div>

            <div class="mental-info-card">
                <h3>💰 Des services gratuits et confidentiels</h3>
                <p>
                    Tous les services mentionnés sur cette page sont gratuits pour les étudiants et respectent
                    la confidentialité de vos échanges.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Numéros d'urgence -->
<section class="mental-emergency">
    <div class="container">
        <div class="emergency-mental-box">
            <h2>⚠️ En cas de crise</h2>
            <p>Si vous ou quelqu'un que vous connaissez êtes en danger immédiat :</p>
            <div class="emergency-numbers-mental">
                <a href="tel:3114" class="emergency-btn">
                    <span class="number">3114</span>
                    <span class="label">Prévention suicide</span>
                </a>
                <a href="tel:15" class="emergency-btn">
                    <span class="number">15</span>
                    <span class="label">SAMU (urgence vitale)</span>
                </a>
            </div>
        </div>
    </div>
</section>