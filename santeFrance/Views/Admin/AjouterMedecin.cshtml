@model SanteFrance.Models.Medecin

@{
    ViewData["Title"] = "Ajouter un Médecin";
}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="sidebar-header">
            <div class="logo-admin">
                <div class="logo-icon">S</div>
                <span class="logo-text">Admin Panel</span>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-action="Dashboard" class="nav-item"><span class="nav-icon">📊</span><span>Dashboard</span></a>
            <a asp-action="Medecins" class="nav-item active"><span class="nav-icon">👨‍⚕️</span><span>Médecins</span></a>
            <a asp-action="Etudiants" class="nav-item"><span class="nav-icon">👥</span><span>Étudiants</span></a>
            <a asp-action="RendezVous" class="nav-item"><span class="nav-icon">📅</span><span>Rendez-vous</span></a>
        </nav>
        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="btn-logout"><span>🚪</span> Déconnexion</a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-header">
            <div class="header-content">
                <div>
                    <h1>➕ Ajouter un médecin</h1>
                    <p>Créer un nouveau compte médecin</p>
                </div>
                <a asp-action="Medecins" class="btn-secondary">← Retour à la liste</a>
            </div>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@Html.Raw(TempData["Success"])</div>
        }

        <div class="form-container">
            <form asp-action="AjouterMedecin" method="post" enctype="multipart/form-data" class="admin-form">
                
                <div class="form-section">
                    <h3>📷 Photo du médecin</h3>
                    <div class="photo-upload-zone" id="photoZone" onclick="document.getElementById('photoMedecin').click()">
                        <img id="photoPreview" class="photo-preview" style="display:none;" alt="Preview" />
                        <span class="photo-upload-icon" id="photoIcon">📷</span>
                        <div class="photo-upload-text" id="photoText">Cliquez pour ajouter une photo</div>
                        <div class="photo-upload-hint">JPG, PNG, GIF ou WebP · Max 5 Mo</div>
                    </div>
                    <input type="file" name="photo" id="photoMedecin" accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;" onchange="previewPhoto(this)" />
                </div>

                <div class="form-section">
                    <h3>👤 Informations personnelles</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Nom">Nom *</label>
                            <input asp-for="Nom" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label asp-for="Prenom">Prénom *</label>
                            <input asp-for="Prenom" class="form-control" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Specialite">Spécialité *</label>
                        <select asp-for="Specialite" class="form-control" required>
                            <option value="">-- Sélectionner --</option>
                            <option value="Médecin Généraliste">Médecin Généraliste</option>
                            <option value="Cardiologue">Cardiologue</option>
                            <option value="Dermatologue">Dermatologue</option>
                            <option value="Gynécologue">Gynécologue</option>
                            <option value="Pédiatre">Pédiatre</option>
                            <option value="Psychiatre">Psychiatre</option>
                            <option value="Ophtalmologue">Ophtalmologue</option>
                            <option value="Dentiste">Dentiste</option>
                            <option value="ORL">ORL</option>
                        </select>
                    </div>
                </div>

                <div class="form-section">
                    <h3>📞 Contact et Connexion</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Telephone">Téléphone</label>
                            <input asp-for="Telephone" type="tel" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="Email">Email (Identifiant) *</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                        </div>
                    </div>
                    
                    <div class="form-group" style="background: lightyellow; padding: 15px; border-radius: 8px;">
                        <label for="motDePasseTemporaire">🔐 Mot de passe temporaire *</label>
                        <input type="text" name="motDePasseTemporaire" id="motDePasseTemporaire" class="form-control" required />
                        <small class="form-text text-muted">Ce mot de passe sera communiqué au médecin pour sa première connexion.</small>
                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="genererMotDePasse()">🎲 Générer</button>
                    </div>

                    <div class="form-group">
                        <label asp-for="Adresse">Adresse *</label>
                        <input asp-for="Adresse" class="form-control" required />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="CodePostal">Code Postal *</label>
                            <input asp-for="CodePostal" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label asp-for="Ville">Ville *</label>
                            <input asp-for="Ville" class="form-control" required />
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h3>ℹ️ Informations complémentaires</h3>
                    <div class="form-group">
                        <label asp-for="Langues">Langues parlées *</label>
                        <input asp-for="Langues" class="form-control" required placeholder="Ex: Français, Anglais" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label><input asp-for="AccepteCarteVitale" type="checkbox" checked /> Accepte Carte Vitale</label>
                        </div>
                        <div class="form-group">
                            <label><input asp-for="TiersPayant" type="checkbox" /> Tiers-payant</label>
                        </div>
                        <div class="form-group">
                            <label><input asp-for="EstActif" type="checkbox" checked /> Actif</label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="Horaires">Horaires</label>
                        <textarea asp-for="Horaires" class="form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">✓ Créer le médecin</button>
                    <a asp-action="Medecins" class="btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('photoPreview').src = e.target.result;
                document.getElementById('photoPreview').style.display = 'block';
                document.getElementById('photoIcon').style.display = 'none';
                document.getElementById('photoText').textContent = input.files[0].name;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function genererMotDePasse() {
        const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
        let pwd = '';
        for (let i = 0; i < 10; i++) {
            pwd += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        document.getElementById('motDePasseTemporaire').value = pwd;
    }
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}