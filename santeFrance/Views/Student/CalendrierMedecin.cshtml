@{
    ViewData["Title"] = "Disponibilités";
    var medecin = ViewBag.Medecin as SanteFrance.Models.Medecin;
    var user = ViewBag.User as SanteFrance.Models.User;
}

<style>
    .calendrier-page {
        min-height: 100vh;
        background: linear-gradient(180deg, #F0FDFA 0%, #F8FAFC 40%);
    }

    /* === TOP BAR === */
    .cal-topbar {
        background: linear-gradient(135deg, #0D9488, #0EA5E9);
        padding: 32px 0 80px;
    }

    .cal-topbar-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .cal-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
    }

        .cal-breadcrumb a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s;
        }

            .cal-breadcrumb a:hover {
                color: white;
            }

        .cal-breadcrumb span {
            color: rgba(255,255,255,0.5);
            font-size: 14px;
        }

    .cal-topbar h1 {
        color: white;
        font-size: 32px;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .cal-topbar p {
        color: rgba(255,255,255,0.85);
        font-size: 16px;
        margin-top: 4px;
    }

    /* === MEDECIN CARD (superposée) === */
    .cal-main {
        max-width: 1200px;
        margin: -48px auto 40px;
        padding: 0 20px;
    }

    .medecin-profile-card {
        background: white;
        border-radius: 16px;
        padding: 28px 32px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
        border: 1px solid #E2E8F0;
    }

    .medecin-avatar-lg {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        background: linear-gradient(135deg, #CCFBF1, #E0F2FE);
        flex-shrink: 0;
        border: 3px solid #0D9488;
    }

    .medecin-details h2 {
        font-size: 22px;
        font-weight: 700;
        color: #0F172A;
        margin-bottom: 4px;
    }

    .medecin-details .specialty {
        color: #0D9488;
        font-weight: 600;
        font-size: 15px;
        margin-bottom: 8px;
    }

    .medecin-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .medecin-tag {
        padding: 4px 12px;
        background: #F0FDFA;
        color: #0F766E;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid #CCFBF1;
    }

    .medecin-contact {
        margin-left: auto;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
        color: #475569;
        font-size: 14px;
    }

        .medecin-contact span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

    /* === FILTRES JOURS === */
    .cal-filters {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .cal-filter-label {
        font-weight: 700;
        color: #0F172A;
        font-size: 15px;
    }

    .cal-filter-btn {
        padding: 8px 18px;
        border: 2px solid #E2E8F0;
        border-radius: 10px;
        background: white;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        transition: all 0.2s;
    }

        .cal-filter-btn:hover {
            border-color: #0D9488;
            color: #0D9488;
            background: #F0FDFA;
        }

        .cal-filter-btn.active {
            background: #0D9488;
            color: white;
            border-color: #0D9488;
        }

    .cal-legend {
        display: flex;
        gap: 20px;
        margin-left: auto;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #475569;
    }

    .legend-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

        .legend-dot.available {
            background: #0D9488;
        }

        .legend-dot.taken {
            background: #F43F5E;
        }

    /* === GRILLE CRÉNEAUX === */
    .creneaux-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
        gap: 14px;
    }

    .creneau-card {
        background: white;
        border: 2px solid #E2E8F0;
        border-radius: 14px;
        padding: 20px 16px;
        text-align: center;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

        .creneau-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: #E2E8F0;
            transition: background 0.2s;
        }

        .creneau-card.disponible {
            border-color: #99F6E4;
            background: #F0FDFA;
            cursor: pointer;
        }

            .creneau-card.disponible::before {
                background: linear-gradient(90deg, #0D9488, #0EA5E9);
            }

            .creneau-card.disponible:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 24px rgba(13, 148, 136, 0.15);
                border-color: #0D9488;
            }

        .creneau-card.occupe {
            border-color: #FECDD3;
            background: #FFF1F2;
            opacity: 0.6;
            cursor: not-allowed;
        }

            .creneau-card.occupe::before {
                background: #F43F5E;
            }

    .creneau-jour {
        font-size: 11px;
        font-weight: 700;
        color: #94A3B8;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .creneau-date {
        font-size: 14px;
        font-weight: 600;
        color: #0F172A;
        margin-bottom: 10px;
    }

    .creneau-heure {
        font-size: 28px;
        font-weight: 800;
        color: #0D9488;
        margin: 8px 0;
        letter-spacing: -1px;
    }

    .creneau-card.occupe .creneau-heure {
        color: #F43F5E;
    }

    .creneau-status {
        font-size: 11px;
        font-weight: 700;
        padding: 4px 14px;
        border-radius: 20px;
        display: inline-block;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .status-disponible {
        background: #0D9488;
        color: white;
    }

    .status-occupe {
        background: #F43F5E;
        color: white;
    }

    .creneaux-empty {
        text-align: center;
        grid-column: 1 / -1;
        padding: 60px 20px;
        color: #94A3B8;
        font-size: 16px;
    }

    /* === MODAL FORMULAIRE === */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        justify-content: center;
        align-items: center;
        overflow-y: auto;
        padding: 20px;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-form {
        background: white;
        border-radius: 20px;
        max-width: 580px;
        width: 100%;
        box-shadow: 0 24px 64px rgba(0,0,0,0.2);
        max-height: 90vh;
        overflow-y: auto;
        animation: modalSlideIn 0.3s ease;
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .modal-header {
        background: linear-gradient(135deg, #0D9488, #0EA5E9);
        color: white;
        padding: 28px 32px;
        border-radius: 20px 20px 0 0;
    }

        .modal-header h2 {
            margin: 0 0 6px 0;
            font-size: 22px;
            font-weight: 700;
        }

        .modal-header p {
            margin: 0;
            opacity: 0.9;
            font-size: 15px;
        }

    .modal-body {
        padding: 32px;
    }

    .form-section {
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid #E2E8F0;
    }

        .form-section:last-of-type {
            border-bottom: none;
            margin-bottom: 0;
        }

        .form-section h3 {
            font-size: 16px;
            color: #0F172A;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
        }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #334155;
            margin-bottom: 8px;
            font-size: 14px;
        }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 2px solid #E2E8F0;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.2s;
    }

        .form-control:focus {
            outline: none;
            border-color: #0D9488;
            box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
        }

    .type-rdv-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .type-rdv-card {
        position: relative;
        cursor: pointer;
    }

        .type-rdv-card input[type="radio"] {
            position: absolute;
            opacity: 0;
        }

    .type-content {
        background: #F8FAFC;
        border: 2px solid #E2E8F0;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all 0.2s;
    }

    .type-rdv-card:hover .type-content {
        border-color: #0D9488;
        background: #F0FDFA;
    }

    .type-rdv-card input:checked + .type-content {
        border-color: #0D9488;
        background: linear-gradient(135deg, #F0FDFA, #CCFBF1);
        box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
    }

    .type-icon {
        font-size: 32px;
        display: block;
        margin-bottom: 8px;
    }

    .type-content strong {
        display: block;
        font-size: 15px;
        color: #0F172A;
    }

    .info-readonly {
        background: #F8FAFC;
        padding: 12px 14px;
        border-radius: 10px;
        font-size: 14px;
        color: #475569;
        border: 1px solid #E2E8F0;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-submit {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #0D9488, #0F766E);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.3);
        }

    .btn-modal-cancel {
        flex: 1;
        padding: 14px;
        background: #F1F5F9;
        color: #475569;
        border: 2px solid #E2E8F0;
        border-radius: 12px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-modal-cancel:hover {
            background: #E2E8F0;
        }

    /* === RESPONSIVE === */
    @@media (max-width: 768px) {
        .medecin-profile-card {
            flex-direction: column;
            text-align: center;
        }

        .medecin-contact {
            margin-left: 0;
            align-items: center;
        }

        .cal-filters {
            flex-direction: column;
            align-items: flex-start;
        }

        .cal-legend {
            margin-left: 0;
        }

        .creneaux-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .type-rdv-options {
            grid-template-columns: 1fr;
        }

        .modal-actions {
            flex-direction: column;
        }
    }
</style>

<div class="calendrier-page">
    <!-- Top Bar -->
    <div class="cal-topbar">
        <div class="cal-topbar-inner">
            <div class="cal-breadcrumb">
                <a href="/">Accueil</a>
                <span>›</span>
                <a href="/Home/Medecins">Médecins</a>
                <span>›</span>
                <a href="#">Disponibilités</a>
            </div>
            <h1>📅 Disponibilités du médecin</h1>
            <p>Choisissez un créneau pour prendre rendez-vous</p>
        </div>
    </div>

    <div class="cal-main">
        <!-- Carte Médecin -->
        <div class="medecin-profile-card">
            <div class="medecin-avatar-lg">
                @if (!string.IsNullOrEmpty(medecin.PhotoUrl) && medecin.PhotoUrl.StartsWith("/uploads/"))
                {
                    <img src="@medecin.PhotoUrl" alt="Dr. @medecin.Prenom" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                }
                else
                {
                    <span>👨‍⚕️</span>
                }
            </div>
            <div class="medecin-details">
                <h2>Dr. @medecin.Prenom @medecin.Nom</h2>
                <div class="specialty">@medecin.Specialite</div>
                <div class="medecin-tags">
                    <span class="medecin-tag">📍 @medecin.Ville</span>
                    @if (medecin.AccepteCarteVitale)
                    {
                        <span class="medecin-tag">💳 Carte Vitale</span>
                    }
                    @if (medecin.TiersPayant)
                    {
                        <span class="medecin-tag">🏥 Tiers payant</span>
                    }
                    <span class="medecin-tag">🌐 @medecin.Langues</span>
                </div>
            </div>
            <div class="medecin-contact">
                @if (!string.IsNullOrEmpty(medecin.Telephone))
                {
                    <span>📞 @medecin.Telephone</span>
                }
                <span>📍 @medecin.Adresse</span>
            </div>
        </div>

        <!-- Filtres -->
        <div class="cal-filters">
            <span class="cal-filter-label">Période :</span>
            <button class="cal-filter-btn active" onclick="setJours(7, this)">7 jours</button>
            <button class="cal-filter-btn" onclick="setJours(14, this)">14 jours</button>
            <button class="cal-filter-btn" onclick="setJours(30, this)">30 jours</button>
            <div class="cal-legend">
                <div class="legend-item">
                    <div class="legend-dot available"></div>
                    <span>Disponible</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot taken"></div>
                    <span>Occupé</span>
                </div>
            </div>
        </div>

        <!-- Grille Créneaux -->
        <div class="creneaux-grid" id="creneauxList">
            <p class="creneaux-empty">Chargement des créneaux...</p>
        </div>
    </div>
</div>

<!-- FORMULAIRE DE PRISE DE RDV -->
<div id="modalFormulaire" class="modal-overlay">
    <div class="modal-form">
        <div class="modal-header">
            <h2>📝 Prendre Rendez-vous</h2>
            <p id="rdvDateTimeDisplay"></p>
        </div>

        <div class="modal-body">
            <form id="formRdv">
                <!-- Informations du RDV -->
                <div class="form-section">
                    <h3>📅 Rendez-vous</h3>

                    <div class="form-group">
                        <label>Médecin</label>
                        <div class="info-readonly">
                            👨‍⚕️ Dr. @medecin.Prenom @medecin.Nom — @medecin.Specialite
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Type de consultation *</label>
                        <div class="type-rdv-options">
                            <label class="type-rdv-card">
                                <input type="radio" name="typeRdv" value="Sur place" checked required>
                                <div class="type-content">
                                    <span class="type-icon">🏥</span>
                                    <strong>Au cabinet</strong>
                                </div>
                            </label>
                            <label class="type-rdv-card">
                                <input type="radio" name="typeRdv" value="Téléphonique" required>
                                <div class="type-content">
                                    <span class="type-icon">📞</span>
                                    <strong>Téléconsultation</strong>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="motif">Motif de consultation (optionnel)</label>
                        <textarea id="motif" name="motif" class="form-control" rows="3" placeholder="Ex: Consultation de routine, mal de gorge, suivi médical..."></textarea>
                    </div>
                </div>

                <!-- Vos informations -->
                <div class="form-section">
                    <h3>👤 Vos informations</h3>

                    <div class="form-group">
                        <label>Nom complet</label>
                        <div class="info-readonly">
                            @user.Prenom @user.Nom
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <div class="info-readonly">
                            📧 @user.Email
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(user.Telephone))
                    {
                        <div class="form-group">
                            <label>Téléphone</label>
                            <div class="info-readonly">
                                📞 @user.Telephone
                            </div>
                        </div>
                    }

                    <p style="font-size: 13px; color: #94A3B8; margin-top: 12px;">
                        💡 Pour modifier vos informations, allez dans <a href="/Student/Profil" style="color: #0D9488; font-weight: 600;">Mon Profil</a>
                    </p>
                </div>

                <!-- Actions -->
                <div class="modal-actions">
                    <button type="submit" class="btn-submit">✅ Confirmer le rendez-vous</button>
                    <button type="button" class="btn-modal-cancel" onclick="fermerFormulaire()">Annuler</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    var medecinId = @medecin.Id;
    var creneauxOccupes = [];
    var rdvEnCours = null;
    var nbJours = 7;

    fetch('/Student/GetCalendarEvents?medecinId=' + medecinId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            creneauxOccupes = Array.isArray(data) ? data : [];
            genererCreneaux();
        })
        .catch(function() { creneauxOccupes = []; genererCreneaux(); });

    function setJours(n, btn) {
        nbJours = n;
        document.querySelectorAll('.cal-filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        genererCreneaux();
    }

    function genererCreneaux() {
        var container = document.getElementById('creneauxList');
        container.innerHTML = '';
        var maintenant = new Date();
        var compteur = 0;

        for (var jour = 0; jour < nbJours; jour++) {
            var date = new Date();
            date.setDate(date.getDate() + jour);
            if (date.getDay() === 0 || date.getDay() === 6) continue;

            for (var heure = 8; heure < 18; heure++) {
                var creneau = new Date(date.getFullYear(), date.getMonth(), date.getDate(), heure, 0, 0, 0);
                if (creneau <= maintenant) continue;

                var creneauTime = creneau.getTime();
                var isOccupe = creneauxOccupes.some(function(rdv) {
                    return creneauTime === new Date(rdv.start).getTime();
                });

                var card = document.createElement('div');
                card.className = 'creneau-card ' + (isOccupe ? 'occupe' : 'disponible');

                var jourStr = creneau.toLocaleDateString('fr-FR', { weekday: 'short' }).toUpperCase();
                var dateStr = creneau.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });

                card.innerHTML =
                    '<div class="creneau-jour">' + jourStr + '</div>' +
                    '<div class="creneau-date">' + dateStr + '</div>' +
                    '<div class="creneau-heure">' + (heure < 10 ? '0' : '') + heure + ':00</div>' +
                    '<span class="creneau-status ' + (isOccupe ? 'status-occupe' : 'status-disponible') + '">' +
                    (isOccupe ? 'Occupé' : 'Disponible') + '</span>';

                if (!isOccupe) {
                    (function(c) {
                        card.addEventListener('click', function() { ouvrirFormulaire(c); });
                    })(new Date(creneau.getTime()));
                }
                container.appendChild(card);
                compteur++;
            }
        }
        if (compteur === 0) {
            container.innerHTML = '<p class="creneaux-empty">Aucun créneau disponible pour cette période.</p>';
        }
    }

    function ouvrirFormulaire(creneau) {
        rdvEnCours = {
            dateHeure: creneau.toISOString(),
            dateFormatted: creneau.toLocaleDateString('fr-FR', {
                weekday: 'long', day: 'numeric', month: 'long',
                year: 'numeric', hour: '2-digit', minute: '2-digit'
            })
        };
        document.getElementById('rdvDateTimeDisplay').textContent = rdvEnCours.dateFormatted;
        document.getElementById('modalFormulaire').classList.add('active');
    }

    function fermerFormulaire() {
        document.getElementById('modalFormulaire').classList.remove('active');
        document.getElementById('formRdv').reset();
        rdvEnCours = null;
    }

    // Fermer la modal en cliquant en dehors
    document.getElementById('modalFormulaire').addEventListener('click', function(e) {
        if (e.target === this) fermerFormulaire();
    });

    document.getElementById('formRdv').addEventListener('submit', function(e) {
        e.preventDefault();
        if (!rdvEnCours) return;
        var typeRdv = document.querySelector('input[name="typeRdv"]:checked').value;
        var motif = document.getElementById('motif').value;
        var formData = new FormData();
        formData.append('medecinId', medecinId);
        formData.append('dateHeure', rdvEnCours.dateHeure);
        formData.append('typeRdv', typeRdv);
        formData.append('motif', motif);

        fetch('/Student/PrendreRendezVousCalendrier', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                alert('✅ RENDEZ-VOUS CONFIRMÉ !');
                window.location.href = '/Student/MesRendezVous';
            } else {
                alert('❌ ' + data.message);
                fermerFormulaire();
                location.reload();
            }
        })
        .catch(function() { alert('❌ Erreur de connexion'); });
    });
</script>